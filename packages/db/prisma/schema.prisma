// Prisma schema — canonical data model for bnmp-monitor.
// Conventions:
//   * Every tenant-scoped table carries tenantId + composite (tenantId, ...) unique constraints.
//   * Encrypted columns use Bytes (bytea) — wrap via @bnmp/db crypto helpers.
//   * Public.* tables are managed by Prisma. pg-boss owns the pgboss schema; do NOT model here.
//   * Supabase Auth lives in auth.* — User.id mirrors auth.users.id (UUID).
//
// Workflow:
//   pnpm --filter @bnmp/db db:generate         # generate client
//   pnpm --filter @bnmp/db db:migrate -- --name <name>  # dev migration
//   pnpm --filter @bnmp/db db:migrate:deploy   # prod
//   pnpm --filter @bnmp/db db:rls              # apply RLS policies (after migrate)
//   pnpm --filter @bnmp/db db:seed             # seed default tenant + cities

generator client {
  provider        = "prisma-client-js"
  previewFeatures = []
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  MODERATOR
  USER
}

enum AlertStatus {
  PENDING
  SENT
  FAILED
  SKIPPED
}

enum WarrantChangeKind {
  CREATED
  UPDATED
  STATUS_CHANGED
  REVOKED
  REPUBLISHED
}

// ─── Tenancy / Auth ──────────────────────────────────────────────────────────

model Tenant {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  plan      String   @default("free")
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users           User[]
  monitoredCities MonitoredCity[]
  warrants        Warrant[]
  telegramConfigs TelegramConfig[]
  alerts          Alert[]
  workerLogs      WorkerLog[]
  pdfAssets       PdfAsset[]

  @@map("tenants")
}

model User {
  // UUID mirrors auth.users.id from Supabase Auth.
  id        String   @id @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  email     String   @unique
  role      Role     @default(USER)
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  telegramConfigs TelegramConfig[]

  @@index([tenantId])
  @@map("users")
}

// ─── BNMP integration domain ─────────────────────────────────────────────────

model MonitoredCity {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  uf           String   @db.Char(2)
  idEstado     Int      @map("id_estado")
  idMunicipio  Int      @map("id_municipio")
  nome         String
  idTipoPeca   Int      @default(1) @map("id_tipo_peca") // 1 = Mandado de Prisão
  idSexo       Int?     @map("id_sexo")
  ativo        Boolean  @default(true)
  // Backfill bookkeeping for retroactive scans
  lastScanAt        DateTime? @map("last_scan_at")
  lastRetroactiveAt DateTime? @map("last_retroactive_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  warrants Warrant[]

  @@unique([tenantId, idEstado, idMunicipio, idTipoPeca], name: "tenant_city_tipo_unique")
  @@index([tenantId, ativo])
  @@map("monitored_cities")
}

model Warrant {
  id                String   @id @default(uuid()) @db.Uuid
  tenantId          String   @map("tenant_id") @db.Uuid
  monitoredCityId   String   @map("monitored_city_id") @db.Uuid
  // BNMP "id" — the dedupe key. Composite with tenantId for multi-tenant isolation.
  bnmpId            BigInt   @map("bnmp_id")
  numeroPeca        String   @map("numero_peca")
  numeroProcesso    String   @map("numero_processo")
  numeroPecaFormatado String @map("numero_peca_formatado")
  nomePessoa        String   @map("nome_pessoa")
  alcunha           String?
  descricaoStatus   String   @map("descricao_status")
  dataExpedicao     DateTime @map("data_expedicao") @db.Date
  nomeOrgao         String   @map("nome_orgao")
  descricaoPeca     String   @map("descricao_peca")
  idTipoPeca        Int      @map("id_tipo_peca")
  nomeMae           String?  @map("nome_mae")
  nomePai           String?  @map("nome_pai")
  descricaoSexo     String   @map("descricao_sexo")
  descricaoProfissao String? @map("descricao_profissao")
  dataNascimento    DateTime? @map("data_nascimento") @db.Date
  // SHA256 hex of the canonical-form payload — used to detect alterations cheaply.
  snapshotHash      String   @map("snapshot_hash")
  // Latest PDF reference (one PdfAsset per warrant; multiple warrants may share an asset by SHA256).
  pdfAssetId        String?  @map("pdf_asset_id") @db.Uuid
  firstSeenAt       DateTime @default(now()) @map("first_seen_at")
  lastSeenAt        DateTime @default(now()) @map("last_seen_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  tenant         Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  monitoredCity  MonitoredCity    @relation(fields: [monitoredCityId], references: [id], onDelete: Cascade)
  pdfAsset       PdfAsset?        @relation(fields: [pdfAssetId], references: [id], onDelete: SetNull)
  history        WarrantHistory[]
  alerts         Alert[]

  @@unique([tenantId, bnmpId], name: "tenant_bnmp_unique")
  @@index([tenantId, dataExpedicao(sort: Desc)])
  @@index([tenantId, descricaoStatus])
  @@index([monitoredCityId])
  @@map("warrants")
}

model WarrantHistory {
  id          String            @id @default(uuid()) @db.Uuid
  tenantId    String            @map("tenant_id") @db.Uuid
  warrantId   String            @map("warrant_id") @db.Uuid
  kind        WarrantChangeKind
  snapshot    Json              @db.JsonB
  snapshotHash String           @map("snapshot_hash")
  diff        Json?             @db.JsonB
  detectedAt  DateTime          @default(now()) @map("detected_at")

  warrant Warrant @relation(fields: [warrantId], references: [id], onDelete: Cascade)

  @@index([warrantId, detectedAt(sort: Desc)])
  @@index([tenantId, detectedAt(sort: Desc)])
  @@map("warrant_history")
}

model TelegramConfig {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  label         String   @default("default")
  // Encrypted at rest via AES-256-GCM (see @bnmp/db crypto). Format: iv(12) | tag(16) | ciphertext.
  botTokenEnc   Bytes    @map("bot_token_enc")
  chatId        String   @map("chat_id")
  alertEnabled  Boolean  @default(true) @map("alert_enabled")
  sendPdf       Boolean  @default(true) @map("send_pdf")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  alerts Alert[]

  @@unique([userId, label], name: "user_label_unique")
  @@index([tenantId, alertEnabled])
  @@map("telegram_configs")
}

model Alert {
  id                String      @id @default(uuid()) @db.Uuid
  tenantId          String      @map("tenant_id") @db.Uuid
  warrantId         String      @map("warrant_id") @db.Uuid
  telegramConfigId  String      @map("telegram_config_id") @db.Uuid
  status            AlertStatus @default(PENDING)
  attempts          Int         @default(0)
  lastError         String?     @map("last_error")
  sentAt            DateTime?   @map("sent_at")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  warrant        Warrant        @relation(fields: [warrantId], references: [id], onDelete: Cascade)
  telegramConfig TelegramConfig @relation(fields: [telegramConfigId], references: [id], onDelete: Cascade)

  @@unique([warrantId, telegramConfigId], name: "warrant_config_unique")
  @@index([status, createdAt])
  @@index([tenantId, status])
  @@map("alerts")
}

// ─── Infra / observability ───────────────────────────────────────────────────

model WorkerLog {
  id            BigInt   @id @default(autoincrement())
  tenantId      String?  @map("tenant_id") @db.Uuid
  correlationId String?  @map("correlation_id")
  jobName       String?  @map("job_name")
  level         String   // "info" | "warn" | "error" | "fatal" | "debug"
  message       String
  context       Json?    @db.JsonB
  createdAt     DateTime @default(now()) @map("created_at")

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([level, createdAt(sort: Desc)])
  @@map("worker_logs")
}

model BnmpSession {
  id             String    @id @default(uuid()) @db.Uuid
  // Encrypted cookie value (portalbnmp=<jwt>). AES-256-GCM same as botToken.
  cookieEnc      Bytes     @map("cookie_enc")
  fingerprint    String
  userAgent      String    @map("user_agent")
  healthy        Boolean   @default(true)
  acquiredCount  Int       @default(0) @map("acquired_count")
  lastUsedAt     DateTime? @map("last_used_at")
  expiresAt      DateTime? @map("expires_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@index([healthy, lastUsedAt])
  @@map("bnmp_sessions")
}

model PdfAsset {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  // Hex SHA256 of file bytes — dedupe key. Same file referenced by many warrants if BNMP recycles.
  sha256       String
  storagePath  String   @map("storage_path") // Supabase Storage key
  sizeBytes    Int      @map("size_bytes")
  contentType  String   @default("application/pdf") @map("content_type")
  bnmpId       BigInt   @map("bnmp_id")
  tipo         Int      @default(1)
  downloadedAt DateTime @default(now()) @map("downloaded_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  warrants Warrant[]

  @@unique([tenantId, sha256], name: "tenant_sha_unique")
  @@index([tenantId, downloadedAt(sort: Desc)])
  @@map("pdf_assets")
}
