  "devDependencies": {
    "@types/tough-cookie": "^4.0.5",
    "@vitest/coverage-v8": "^2.1.8",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
