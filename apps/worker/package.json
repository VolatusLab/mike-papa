{
  "name": "@bnmp/worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "tsx src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --max-warnings 0",
    "clean": "rimraf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@bnmp/bnmp": "workspace:*",
    "@bnmp/db": "workspace:*",
    "@bnmp/logger": "workspace:*",
    "@bnmp/queue": "workspace:*",
    "@bnmp/shared": "workspace:*",
    "@bnmp/telegram": "workspace:*",
    "pg-boss": "^10.1.6",
    "tsx": "^4.19.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.3"
  }
}
