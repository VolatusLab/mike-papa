BNMP_BASE_URL=https://portalbnmp.cnj.jus.br/bnmpportal
BNMP_POLL_INTERVAL_CRON=*/5 * * * *
BNMP_RATE_LIMIT_RPM=30
BNMP_USER_AGENT=bnmp-monitor/0.0 (+contact@example.com)

TELEGRAM_BOT_TOKEN_DEFAULT=

WORKER_PORT=8080
