# Worker env — copy to apps/worker/.env or root .env

NODE_ENV=development
LOG_LEVEL=info

DATABASE_URL=postgresql://bnmp:bnmp_dev_password@localhost:5432/bnmp
PGBOSS_SCHEMA=pgboss

SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
