{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "ES2022"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "allowJs": true,
    "noEmit": true,
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@bnmp/shared": ["../../packages/shared/src/index.ts"],
      "@bnmp/shared/*": ["../../packages/shared/src/*"],
      "@bnmp/db": ["../../packages/db/src/index.ts"],
      "@bnmp/db/*": ["../../packages/db/src/*"],
      "@bnmp/logger": ["../../packages/logger/src/index.ts"],
      "@bnmp/logger/*": ["../../packages/logger/src/*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules", ".next"]
}
