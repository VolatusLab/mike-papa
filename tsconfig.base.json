{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "incremental": true,
    "composite": false,
    "baseUrl": ".",
    "paths": {
      "@bnmp/shared": ["packages/shared/src/index.ts"],
      "@bnmp/shared/*": ["packages/shared/src/*"],
      "@bnmp/db": ["packages/db/src/index.ts"],
      "@bnmp/db/*": ["packages/db/src/*"],
      "@bnmp/bnmp": ["packages/bnmp/src/index.ts"],
      "@bnmp/bnmp/*": ["packages/bnmp/src/*"],
      "@bnmp/telegram": ["packages/telegram/src/index.ts"],
      "@bnmp/telegram/*": ["packages/telegram/src/*"],
      "@bnmp/logger": ["packages/logger/src/index.ts"],
      "@bnmp/logger/*": ["packages/logger/src/*"],
      "@bnmp/queue": ["packages/queue/src/index.ts"],
      "@bnmp/queue/*": ["packages/queue/src/*"]
    }
  },
  "exclude": ["node_modules", "dist", ".next", ".turbo", "coverage"]
}
