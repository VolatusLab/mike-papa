{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalDependencies": [".env", ".env.local", "tsconfig.base.json"],
  "globalEnv": [
    "NODE_ENV",
    "LOG_LEVEL",
    "SKIP_ENV_VALIDATION",
    "NEXT_PHASE",
    "DATABASE_URL",
    "DIRECT_URL",
    "PGBOSS_SCHEMA",
    "SUPABASE_URL",
    "SUPABASE_SERVICE_ROLE_KEY",
    "SUPABASE_STORAGE_BUCKET",
    "NEXT_PUBLIC_SUPABASE_URL",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY",
    "ENCRYPTION_KEY",
    "BNMP_BASE_URL",
    "BNMP_POLL_INTERVAL_CRON",
    "BNMP_RATE_LIMIT_RPM",
    "BNMP_USER_AGENT",
    "TELEGRAM_BOT_TOKEN_DEFAULT",
    "WORKER_PORT"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "clean": {
      "cache": false
    }
  }
}
